# Google Maps API key (required for Street View embeds in production)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Google Maps API key for local development Street View (optional — Street View disabled if unset)
SECRET_DEV_GOOGLE_MAPS_API_KEY=

# ATTOM API key — only needed to regenerate data/attom-data.json via `npm run fetch:attom`
# Not required for running the app itself
ATTOM_API_KEY=
